# Copia este archivo como .env y completa los valores en tu VPS.
# docker compose lee .env automáticamente para estas variables.

# Clave de la base de datos PostgreSQL (usa una fuerte en producción)
POSTGRES_PASSWORD=cambia-esta-clave-segura

# Secreto de sesión para Auth.js. Genera uno con: npx auth secret
AUTH_SECRET=pega-aqui-un-secreto-largo-y-aleatorio

# Token para proteger el endpoint /api/cron/recalcular
CRON_SECRET=token-seguro-para-el-cron

# Ponlo en "true" SOLO en el primer despliegue para crear usuarios y
# configuración inicial. Luego déjalo en "false".
RUN_SEED=true

# --- Solo para desarrollo local (npm run dev contra Postgres local) ---
# DATABASE_URL="postgresql://creditos:creditos@localhost:5432/creditos?schema=public"
